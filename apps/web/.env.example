NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Groq API key for the Natural Language Query endpoint (/api/nlq).
# Server-side only — never exposed to the browser. Free key from
# https://console.groq.com/keys. Set this locally in apps/web/.env.local
# and in Vercel project settings (Settings → Environment Variables) for
# Production and Preview environments.
GROQ_API_KEY=
